# Lumencore — VPS environment template
# Copy to /opt/lumencore/.env on VPS and fill in all values before deploying.
# NEVER commit the real .env file.

# --- Postgres ---
POSTGRES_USER=lumencore
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=lumencore

# --- Redis ---
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Celery ---
CELERY_POOL=solo
CELERY_CONCURRENCY=2

# --- Release metadata ---
LUMENCORE_SYSTEM_PHASE=27
LUMENCORE_RELEASE_ID=phase2
LUMENCORE_RELEASE_MANIFEST_SHA256=unset

# --- Optional: external API keys (add as needed) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
