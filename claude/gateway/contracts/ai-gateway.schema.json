{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lumencore.local/contracts/ai-gateway.v1.json",
  "title": "Lumencore AI Gateway v1",
  "type": "object",
  "required": ["request"],
  "properties": {
    "request": {
      "type": "object",
      "required": ["request_id", "origin", "policy", "prompt", "provider"],
      "properties": {
        "request_id": { "type": "string", "minLength": 8 },
        "origin": {
          "type": "object",
          "required": ["system", "operation"],
          "properties": {
            "system": { "type": "string", "enum": ["lumencore", "openclaw"] },
            "operation": { "type": "string" },
            "user_id": { "type": "string" },
            "tenant_id": { "type": "string" }
          },
          "additionalProperties": false
        },
        "provider": {
          "type": "object",
          "required": ["name", "model"],
          "properties": {
            "name": { "type": "string", "enum": ["claude", "openai", "mock"] },
            "model": { "type": "string" },
            "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
            "max_tokens": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        },
        "policy": {
          "type": "object",
          "required": ["policy_version", "mode"],
          "properties": {
            "policy_version": { "type": "string", "pattern": "^v[0-9]+$" },
            "mode": { "type": "string", "enum": ["strict", "standard", "relaxed"] },
            "redaction_profile": { "type": "string" }
          },
          "additionalProperties": false
        },
        "prompt": {
          "type": "object",
          "required": ["template_id", "template_version", "input"],
          "properties": {
            "template_id": { "type": "string" },
            "template_version": { "type": "string" },
            "input": { "type": "object" }
          },
          "additionalProperties": false
        },
        "timeout_ms": { "type": "integer", "minimum": 1000, "maximum": 120000 },
        "metadata": { "type": "object" }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["request_id", "status", "output", "usage", "trace"],
      "properties": {
        "request_id": { "type": "string" },
        "status": { "type": "string", "enum": ["ok", "blocked", "error", "timeout"] },
        "output": {
          "type": "object",
          "properties": {
            "text": { "type": "string" },
            "json": { "type": "object" }
          },
          "additionalProperties": false
        },
        "usage": {
          "type": "object",
          "required": ["input_tokens", "output_tokens", "estimated_cost_usd"],
          "properties": {
            "input_tokens": { "type": "integer", "minimum": 0 },
            "output_tokens": { "type": "integer", "minimum": 0 },
            "estimated_cost_usd": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "trace": {
          "type": "object",
          "required": ["trace_id", "provider_latency_ms", "gateway_latency_ms"],
          "properties": {
            "trace_id": { "type": "string" },
            "provider_latency_ms": { "type": "integer", "minimum": 0 },
            "gateway_latency_ms": { "type": "integer", "minimum": 0 },
            "provider_request_id": { "type": "string" }
          },
          "additionalProperties": false
        },
        "error": {
          "type": "object",
          "properties": {
            "code": { "type": "string" },
            "message": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}